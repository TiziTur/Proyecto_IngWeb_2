{
  "version": 2,
  "buildCommand": "rm -rf public && mkdir -p public && cp -R Frontend/public/. public/",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/", "destination": "/src/html/index.html" },
    { "source": "/en", "destination": "/src/html/en.html" },
    { "source": "/login", "destination": "/src/html/login.html" },
    { "source": "/(.*)", "destination": "/src/$1" }
  ]
}
